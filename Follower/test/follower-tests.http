### =====================================================
### Follower Microservice — API Tests
### Base: http://localhost:8084/api/v1
### Auth:  http://localhost:8081
### =====================================================
### All requests after Step 1 use {{auth_token}} captured
### from the login response. Run requests top to bottom.
### =====================================================


### Step 1: Login and capture JWT
POST http://localhost:8081/auth/login
Content-Type: application/json

{
  "identifier": "admin",
  "password": "Password123!"
}

> {%
    client.test("Admin login successful", function() {
        client.assert(response.status === 200, "Expected 200");
        client.assert(
            response.body.token || response.body.jwt || response.body.access_token,
            "Expected a token in response"
        );
    });

    const body = response.body;
    const token = body.token || body.jwt || body.access_token;

    if (!token) {
        throw new Error("JWT not found in response. Body: " + JSON.stringify(body));
    }

    client.global.set("auth_token", token);
    client.log("Token stored: " + token.substring(0, 20) + "...");
%}

### Step 2: Follow a user (token holder follows user 2)
POST http://localhost:8084/api/v1/followers/follow/2
Authorization: Bearer {{auth_token}}

> {%
    client.test("Follow user - 200 OK", function() {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
        client.assert(response.body === "User followed successfully!", "Unexpected body: " + response.body);
    });
%}


### Step 3: Attempt to follow same user again (expect 400)
POST http://localhost:8084/api/v1/followers/follow/2
Authorization: Bearer {{auth_token}}

> {%
    client.test("Follow duplicate - 400 Bad Request", function() {
        client.assert(response.status === 400, "Expected 400, got " + response.status);
    });
%}


### Step 4: Follow a second user (token holder follows user 3)
POST http://localhost:8084/api/v1/followers/follow/3
Authorization: Bearer {{auth_token}}

> {%
    client.test("Follow second user - 200 OK", function() {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
    });
%}



### Step 5: Get list of users the token holder is following
GET http://localhost:8084/api/v1/followers/following
Authorization: Bearer {{auth_token}}

> {%
    client.test("Get following - 200 OK", function() {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
        client.assert(Array.isArray(response.body), "Expected array");
        client.assert(response.body.length >= 2, "Expected at least 2 followed users");
    });
%}


### Step 6: Get the token holder's followers list
GET http://localhost:8084/api/v1/followers/followers-list
Authorization: Bearer {{auth_token}}

> {%
    client.test("Get followers - 200 OK", function() {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
        client.assert(Array.isArray(response.body), "Expected array");
    });
%}


### Step 7: Check if token holder is following user 2 (expect true)
GET http://localhost:8084/api/v1/followers/is-following/2
Authorization: Bearer {{auth_token}}

> {%
    client.test("Is following user 2 - true", function() {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
        client.assert(response.body === true, "Expected true, got " + response.body);
    });
%}


### Step 8: Check if token holder is following user 99 (expect false)
GET http://localhost:8084/api/v1/followers/is-following/99
Authorization: Bearer {{auth_token}}

> {%
    client.test("Is following unknown user - false", function() {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
        client.assert(response.body === false, "Expected false, got " + response.body);
    });
%}



### Step 9: Get paginated feed (blogs from followed users)
GET http://localhost:8084/api/v1/followers/feed?limit=5
Authorization: Bearer {{auth_token}}

> {%
    client.test("Get paginated feed - 200 OK", function() {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
        client.assert(Array.isArray(response.body), "Expected array");
        client.assert(response.body.length <= 5, "Expected at most 5 results");
    });
%}


### Step 10: Get full feed (no limit)
GET http://localhost:8084/api/v1/followers/all-blogs
Authorization: Bearer {{auth_token}}

> {%
    client.test("Get all blogs feed - 200 OK", function() {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
        client.assert(Array.isArray(response.body), "Expected array");
    });
%}


### Step 11: Get follow recommendations (friends of friends)
GET http://localhost:8084/api/v1/followers/recommendations?limit=10
Authorization: Bearer {{auth_token}}

> {%
    client.test("Get recommendations - 200 OK", function() {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
        client.assert(Array.isArray(response.body), "Expected array");
        client.log("Recommended users: " + response.body.length);
    });
%}


### Step 12: Get the token holder's own profile
GET http://localhost:8084/api/v1/followers/me
Authorization: Bearer {{auth_token}}

> {%
    client.test("Get own profile - 200 OK", function() {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
        client.assert(response.body !== null, "Expected a user object");
    });
%}


### Step 13: Get another user's profile by ID
GET http://localhost:8084/api/v1/followers/user/2
Authorization: Bearer {{auth_token}}

> {%
    client.test("Get user 2 profile - 200 OK", function() {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
        client.assert(response.body !== null, "Expected a user object");
    });
%}


### Step 14: Get a non-existent user's profile (expect 404)
GET http://localhost:8084/api/v1/followers/user/999999
Authorization: Bearer {{auth_token}}

> {%
    client.test("Get unknown user profile - 404", function() {
        client.assert(response.status === 404, "Expected 404, got " + response.status);
    });
%}


### Step 15: Unfollow user 2
DELETE http://localhost:8084/api/v1/followers/unfollow/2
Authorization: Bearer {{auth_token}}

> {%
    client.test("Unfollow user 2 - 200 OK", function() {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
        client.assert(response.body === "User unfollowed successfully!", "Unexpected body: " + response.body);
    });
%}


### Step 16: Confirm user 2 is no longer followed
GET http://localhost:8084/api/v1/followers/is-following/2
Authorization: Bearer {{auth_token}}

> {%
    client.test("Is following user 2 after unfollow - false", function() {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
        client.assert(response.body === false, "Expected false after unfollow, got " + response.body);
    });
%}


### Step 17: Confirm feed no longer includes user 2's blogs
GET http://localhost:8084/api/v1/followers/feed
Authorization: Bearer {{auth_token}}

> {%
    client.test("Feed after unfollow - 200 OK", function() {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
        client.assert(Array.isArray(response.body), "Expected array");
        client.log("Feed size after unfollow: " + response.body.length);
    });
%}


### =====================================================
### AUTH GUARD CHECKS
### =====================================================

### Step 18: Request without token (expect 401)
GET http://localhost:8084/api/v1/followers/feed

> {%
    client.test("No token - 401 Unauthorized", function() {
        client.assert(response.status === 401, "Expected 401, got " + response.status);
    });
%}


### Step 19: Request with a malformed token (expect 401)
GET http://localhost:8084/api/v1/followers/feed
Authorization: Bearer this.is.not.a.valid.jwt

> {%
    client.test("Bad token - 401 Unauthorized", function() {
        client.assert(response.status === 401, "Expected 401, got " + response.status);
    });
%}
