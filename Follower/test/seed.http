## =====================================================
## Seed Script — Initialize test data
## Run top to bottom in order.
##
## Services:
##   Auth         → http://localhost:8081
##   Stakeholders → http://localhost:8082
##   Blog         → http://localhost:8080
##
## Creates:
##   3 users (admin already exists via db seed)
##   3 profiles in Stakeholders
##   4 blogs in Blog service (2 by user_b, 2 by user_c)
##   alice follows bob and carol via the follower service
## =====================================================


### ── STEP 1: Register User A (alice) ──────────────────
### We capture the token and user_id for use in later steps.
POST http://localhost:8081/auth/register
Content-Type: application/json

{
  "username": "alice",
  "email": "alice@example.com",
  "password": "Password123!"
}

> {%
    client.test("Register alice - 201", function() {
        client.assert(response.status === 201, "Expected 201, got " + response.status + ": " + JSON.stringify(response.body));
    });
    client.global.set("alice_token", response.body.token);
    client.global.set("alice_id", response.body.user_id);
    client.log("alice id=" + response.body.user_id);
%}


### ── STEP 2: Register User B (bob) ───────────────────
POST http://localhost:8081/auth/register
Content-Type: application/json

{
  "username": "bob",
  "email": "bob@example.com",
  "password": "Password123!"
}

> {%
    client.test("Register bob - 201", function() {
        client.assert(response.status === 201, "Expected 201, got " + response.status + ": " + JSON.stringify(response.body));
    });
    client.global.set("bob_token", response.body.token);
    client.global.set("bob_id", response.body.user_id);
    client.log("bob id=" + response.body.user_id);
%}


### ── STEP 3: Register User C (carol) ─────────────────
POST http://localhost:8081/auth/register
Content-Type: application/json

{
  "username": "carol",
  "email": "carol@example.com",
  "password": "Password123!"
}

> {%
    client.test("Register carol - 201", function() {
        client.assert(response.status === 201, "Expected 201, got " + response.status + ": " + JSON.stringify(response.body));
    });
    client.global.set("carol_token", response.body.token);
    client.global.set("carol_id", response.body.user_id);
    client.log("carol id=" + response.body.user_id);
%}


### ── STEP 4: Login as admin (seeded via db/seed.sql) ─
POST http://localhost:8081/auth/login
Content-Type: application/json

{
  "identifier": "admin",
  "password": "Password123!"
}

> {%
    client.test("Login admin - 200", function() {
        client.assert(response.status === 200, "Expected 200, got " + response.status + ": " + JSON.stringify(response.body));
    });
    const token = response.body.token || response.body.jwt || response.body.access_token;
    client.global.set("admin_token", token);
    client.log("admin token stored");
%}


### ── STEP 5: Create Stakeholder profile for alice ────
### /profiles/create has no auth requirement
POST http://localhost:8082/profiles/create
Content-Type: application/json

{
  "user_id": {{alice_id}},
  "name": "Alice",
  "lastname": "Smith",
  "biography": "Travel enthusiast and blogger.",
  "role": "tourist"
}

> {%
    client.test("Create alice profile - 200/201", function() {
        client.assert(response.status === 200 || response.status === 201,
            "Expected 200 or 201, got " + response.status + ": " + JSON.stringify(response.body));
    });
%}


### ── STEP 6: Create Stakeholder profile for bob ──────
POST http://localhost:8082/profiles/create
Content-Type: application/json

{
  "user_id": {{bob_id}},
  "name": "Bob",
  "lastname": "Jones",
  "biography": "Mountain hiker and photographer.",
  "role": "tourist"
}

> {%
    client.test("Create bob profile - 200/201", function() {
        client.assert(response.status === 200 || response.status === 201,
            "Expected 200 or 201, got " + response.status + ": " + JSON.stringify(response.body));
    });
%}


