### ── STEP 8: Bob writes a blog ───────────────────────
### Blog service reads authorId from the request body (no JWT extraction yet)
POST http://localhost:8080/blogs
Content-Type: application/json

{
  "authorId": {{bob_id}},
  "title": "Hiking Kopaonik in Winter",
  "description": "A detailed guide to the best ski and hiking trails on Kopaonik mountain.",
  "imageUrls": []
}

> {%
    client.test("Bob blog 1 - 200/201", function() {
        client.assert(response.status === 200 || response.status === 201,
            "Expected 200 or 201, got " + response.status + ": " + JSON.stringify(response.body));
    });
    client.global.set("bob_blog_1_id", response.body.id);
%}


