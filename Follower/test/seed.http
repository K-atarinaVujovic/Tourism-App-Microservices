### ── STEP 12: Alice follows Bob ─────────────────────
### Uses alice's JWT — follower service reads her id from the token
POST http://localhost:8084/followers/follow/{{bob_id}}
Authorization: Bearer {{alice_token}}

> {%
    client.test("Alice follows bob - 200", function() {
        client.assert(response.status === 200,
            "Expected 200, got " + response.status + ": " + JSON.stringify(response.body));
    });
%}


### ── STEP 13: Alice follows Carol ───────────────────
POST http://localhost:8084/followers/follow/{{carol_id}}
Authorization: Bearer {{alice_token}}

> {%
    client.test("Alice follows carol - 200", function() {
        client.assert(response.status === 200,
            "Expected 200, got " + response.status + ": " + JSON.stringify(response.body));
    });
%}


### ── STEP 14: Bob follows Carol ─────────────────────
### This sets up the friends-of-friends chain:
### alice → bob → carol, so carol will appear in alice's recommendations
POST http://localhost:8084/followers/follow/{{carol_id}}
Authorization: Bearer {{bob_token}}

> {%
    client.test("Bob follows carol - 200", function() {
        client.assert(response.status === 200,
            "Expected 200, got " + response.status + ": " + JSON.stringify(response.body));
    });
%}


### ── STEP 15: Sanity check — verify alice's feed has blogs ──
GET http://localhost:8084/followers/feed
Authorization: Bearer {{alice_token}}

> {%
    client.test("Alice feed is non-empty - 200", function() {
        client.assert(response.status === 200,
            "Expected 200, got " + response.status + ": " + JSON.stringify(response.body));
        client.assert(Array.isArray(response.body) && response.body.length > 0,
            "Expected at least one blog in alice's feed, got: " + JSON.stringify(response.body));
    });
    client.log("Alice's feed contains " + response.body.length + " blogs");
%}


### ── STEP 16: Sanity check — verify alice's following list ──
GET http://localhost:8084/followers/following
Authorization: Bearer {{alice_token}}

> {%
    client.test("Alice following list - 200", function() {
        client.assert(response.status === 200,
            "Expected 200, got " + response.status + ": " + JSON.stringify(response.body));
        client.assert(response.body.length === 2,
            "Expected alice to follow 2 users, got " + response.body.length);
    });
%}


### ── DONE ─────────────────────────────────────────────
### Tokens and IDs are stored in client globals and can
### be used directly in follower-tests.http:
###
###   alice_token, alice_id
###   bob_token,   bob_id
###   carol_token, carol_id
###   admin_token
###
### To reset: delete Neo4j nodes, truncate blogs and
### users tables, then re-run this script from step 1.
###
### Neo4j reset (run in browser at localhost:7474):
###   MATCH (n) DETACH DELETE n
